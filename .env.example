# Fireworks credentials for LOCAL dev/smoke-testing only.
# Copy to .env (gitignored) and fill in. The submission image reads these
# from the harness at eval time — never bundle your key in the image.
FIREWORKS_API_KEY=fw_your_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Use the model IDs your base_url actually serves. On public Fireworks these
# are full paths, e.g.:
ALLOWED_MODELS=accounts/fireworks/models/gemma-2-9b-it,accounts/fireworks/models/qwen2p5-coder-7b
